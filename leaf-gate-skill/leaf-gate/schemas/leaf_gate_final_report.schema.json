{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Leaf Gate Final Report",
  "type": "object",
  "required": ["node_id", "decision", "summary", "static_checks", "llm_judgement", "next_action"],
  "properties": {
    "node_id": { "type": "string" },
    "decision": {
      "type": "string",
      "enum": ["LEAF_READY", "NEEDS_DECOMPOSITION", "NEEDS_REFINEMENT"]
    },
    "summary": { "type": "string" },
    "thresholds": { "type": "object" },
    "config": { "type": "object" },
    "static_checks": { "type": "object" },
    "llm_judgement": { "type": "object" },
    "refinement_routes": { "type": "array" },
    "next_action": { "type": "object" }
  }
}
