{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Leaf Gate Report",
  "type": "object",
  "required": ["node_id", "decision", "summary", "static_checks", "next_action"],
  "properties": {
    "node_id": { "type": "string" },
    "decision": {
      "type": "string",
      "enum": [
        "LEAF_READY",
        "NEEDS_DECOMPOSITION",
        "NEEDS_REFINEMENT",
        "STATIC_PASS_REQUIRES_LLM"
      ]
    },
    "summary": { "type": "string" },
    "static_checks": { "type": "object" },
    "llm_judgement": { "type": ["object", "null"] },
    "refinement_routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["target", "criterion", "reason", "actions", "evidence"],
        "properties": {
          "target": {
            "type": "string",
            "enum": ["architecture", "testcase", "owner_decision"]
          },
          "criterion": { "type": "string" },
          "reason": { "type": "string" },
          "actions": {
            "type": "array",
            "items": { "type": "string" }
          },
          "evidence": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "next_action": {
      "type": "object",
      "required": ["type", "children", "notes"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["decompose", "refine_spec", "vibecode"]
        },
        "children": {
          "type": "array",
          "items": { "type": "string" }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
