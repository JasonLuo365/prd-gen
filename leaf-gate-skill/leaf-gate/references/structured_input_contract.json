{
  "schema_version": "1.0",
  "required_artifacts": ["prd.json", "architecture.json", "testcases.json", "mocktest_report.json|leaf_gate_evidence.json"],
  "common_fields_required_on_every_artifact": ["schema_version", "run_id", "project_id", "node_id", "parent_node_id", "artifact_id", "artifact_type", "created_at", "generator", "status", "input_artifacts", "requirement_ids"],
  "identity_fields": ["schema_version", "run_id", "project_id", "node_id"],
  "prd": {"required": ["requirements", "depth", "max_depth", "node_history"], "requirements_item": "string or {id: string}", "node_history_type": "array"},
  "architecture": {"recommended": ["components", "interfaces", "dependencies", "depth", "complexity", "risks"]},
  "testcases": {"required": ["testcases"], "testcase_item": {"required": ["requirement_ids", "status"]}},
  "mocktest": {"required": ["status", "defects"], "accepted_status_before_decision": "PASS"}
}
